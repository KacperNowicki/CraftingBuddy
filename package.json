{
  "name": "craftingbuddy",
  "version": "0.3.6",
  "license": "MIT",
  "homepage": "https://kacpernowicki.github.io/CraftingBuddy/",
  "repository": {
    "type": "git",
    "url": "https://github.com/KacperNowicki/CraftingBuddy.git"
  },
  "type": "module",
  "bin": "app/craft-plan-app.mjs",
  "scripts": {
    "app": "node app/craft-plan-app.mjs",
    "check": "node --check app/craft-plan-app.mjs && node --check scripts/scrape-goblin.mjs && node --check scripts/scrape-undermine-api.mjs && node --check scripts/build-craft-plan.mjs",
    "generate:icons": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "build:exe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-exe.ps1"
  },
  "pkg": {
    "assets": [
      "CraftPlanExporter/CraftPlanExporter.toc",
      "CraftPlanExporter/Main.lua",
      "CraftPlanExporter/Media/CraftingBuddyIcon.tga",
      "data/undermine-silvermoon-eu-crafting.json",
      "scripts/*.mjs"
    ]
  }
}
